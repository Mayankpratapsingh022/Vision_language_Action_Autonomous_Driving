{
  "dataset_repo": "Mayank022/urban-vla-left-turn-human",
  "model_repo": "Mayank022/urban-vla-left-turn-smolvla",
  "base_model": "lerobot/smolvla_base",
  "run_name": "smolvla-left-turn-v1",
  "seed": 42,
  "fps": 10,
  "video_backend": "pyav",
  "steps": 20000,
  "batch_size": 32,
  "num_workers": 8,
  "chunk_size": 20,
  "action_steps": 3,
  "eval_split": 0.1,
  "eval_interval": 1000,
  "save_interval": 2000,
  "log_interval": 20,
  "warmup_steps": 1000,
  "max_eval_samples": 2000,
  "freeze_vision_encoder": false,
  "train_expert_only": false,
  "image_augmentation": true,
  "push_to_hub": true,
  "rename_map": {
    "observation.images.front": "observation.images.camera1"
  }
}
